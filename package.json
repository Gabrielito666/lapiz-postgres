{
  "name": "lapiz-postgres",
  "version": "1.0.2-beta",
  "description": "An npm library of abstract classes to create a postgres SDK",
  "main": "index.js",
  "imports": {
  	"#lib/*": "./lib/*",
  	"#test/*": "./test/*"
  },
  "exports": {
  	"./db": { "default": "./lib/db/index.js" },
	"./query": { "default": "./lib/query/index.js"},
	"./test-helpers": { "default": "./lib/test-helpers/index.js" }
  },
  "scripts": {
    "test": "node --test test/unit/index.test.js test/integration/index.test.js",
    "test:unit": "node --test test/unit/index.test.js",
    "test:integration": "node --test test/integration/index.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "pg": "^8.20.0"
  }
}
